# Supabase — server-side only, never use NEXT_PUBLIC_ prefix
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# AgentMail — inbox that receives Taiga report emails
# Create at: https://agentmail.tools
AGENTMAIL_API_KEY=
AGENTMAIL_INBOX_ID=

# Cron security — Vercel passes this in Authorization: Bearer <secret>
# Generate with: openssl rand -hex 32
CRON_SECRET=
